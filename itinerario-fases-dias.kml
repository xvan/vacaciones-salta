        <styleUrl>#fase1</styleUrl>
        <description>Paseo opcional al llegar con luz de tarde (~16:30-18:00).</description>
        <TimeStamp><when>2026-03-21</when></TimeStamp>
        <Point><coordinates>-65.4117,-23.5758,0</coordinates></Point>
      </Placemark>
