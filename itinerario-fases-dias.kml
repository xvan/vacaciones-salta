        <styleUrl>#fase1</styleUrl>
        <description>Parada y descanso en costanera. Salida 08:00, llegada ~15:00.</description>
        <TimeStamp><when>2026-03-19</when></TimeStamp>
        <Point><coordinates>-63.2476,-32.4075,0</coordinates></Point>
      </Placemark>
      <Placemark>
